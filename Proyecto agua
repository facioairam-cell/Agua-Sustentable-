<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Siembra Inteligente - Proyecto Airam, Brisa, Joshuan y Pedro</title>
    <style>
        :root {
            --primary: #1e3a8a;
            --primary-light: #3b82f6;
            --accent: #10b981;
            --accent-dark: #047857;
            --bg-light: #f4f6f9;
            --text-dark: #1f2937;
            --text-muted: #4b5563;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--bg-light); color: var(--text-dark); line-height: 1.6; }
        
        header { 
            background: linear-gradient(135deg, #1e3a8a, #0d9488); 
            color: white; 
            padding: 50px 20px; 
            text-align: center; 
            border-bottom: 5px solid var(--accent); 
        }
        header h1 { font-size: 2.5rem; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
        .badge { 
            background-color: var(--accent); 
            color: white; 
            padding: 6px 15px; 
            border-radius: 20px; 
            font-size: 0.9rem; 
            display: inline-block; 
            margin-top: 15px; 
            font-weight: bold; 
            text-transform: uppercase; 
        }

        main { max-width: 1100px; margin: 30px auto; padding: 0 20px; }

        .intro-box { 
            background: white; 
            padding: 35px; 
            border-radius: 15px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.08); 
            margin-bottom: 35px; 
            border-left: 8px solid var(--primary-light); 
        }
        .intro-box h2 { color: var(--primary); margin-bottom: 15px; }

        .stats-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
            gap: 20px; 
            margin-bottom: 40px; 
        }
        .stat-card { 
            background: white; 
            padding: 25px; 
            border-radius: 12px; 
            text-align: center; 
            border: 1px solid #e2e8f0; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            transition: transform 0.3s;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-card h4 { font-size: 2.2rem; color: var(--primary-light); margin-bottom: 5px; }
        .stat-card p { font-size: 0.85rem; color: var(--text-muted); font-weight: bold; }

        .grid { 
            display: grid; 
            grid-template-columns: 1fr; 
            gap: 25px; 
            margin-bottom: 35px; 
        }
        @media (min-width: 768px) { .grid { grid-template-columns: 1fr 1fr; } }

        .card { 
            background: white; 
            border-radius: 12px; 
            padding: 25px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
            height: 100%;
        }
        .card h3 { 
            color: var(--primary); 
            margin-bottom: 15px; 
            padding-bottom: 10px; 
            border-bottom: 2px solid #f1f5f9; 
        }
        .card ul { list-style-type: none; }
        .card li { margin-bottom: 12px; padding-left: 30px; position: relative; font-size: 0.95rem; }
        .card li::before { content: "✔"; position: absolute; left: 0; color: var(--accent); font-weight: bold; }

        .data-table-container {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-bottom: 40px;
            overflow-x: auto;
        }
        table { width: 100%; border-collapse: collapse; min-width: 500px; }
        th { background: var(--primary); color: white; padding: 12px; text-align: left; }
        td { padding: 12px; border-bottom: 1px solid #e2e8f0; font-size: 0.9rem; }
        tr:nth-child(even) { background: #f8fafc; }

        .simulator-section { 
            background: #ffffff; 
            border-radius: 20px; 
            padding: 40px; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.1); 
            border: 1px solid #e2e8f0; 
        }
        .simulator-section h2 { color: var(--primary); text-align: center; font-size: 2rem; margin-bottom: 30px; }

        .sim-grid { 
            display: grid; 
            grid-template-columns: 1fr; 
            gap: 35px; 
        }
        @media (min-width: 850px) { .sim-grid { grid-template-columns: 1fr 1.3fr; } }

        .controls { background: #f8fafc; padding: 30px; border-radius: 15px; border: 1px solid #e2e8f0; }
        .control-group { margin-bottom: 20px; }
        .control-group label { display: block; font-weight: bold; margin-bottom: 10px; color: var(--primary); }
        .control-group select { width: 100%; padding: 12px; border-radius: 10px; border: 2px solid #cbd5e1; font-size: 1rem; }

        .btn-sim { 
            width: 100%; 
            background: linear-gradient(135deg, var(--accent-dark), var(--accent)); 
            color: white; 
            border: none; 
            padding: 18px; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            font-weight: bold; 
            cursor: pointer; 
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-sim:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(16, 185, 129, 0.4); }

        .results { 
            background: #f0fdf4; 
            border: 2px dashed #bbf7d0; 
            border-radius: 15px; 
            padding: 30px; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
        }
        .metric-box { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px; }
        .metric { background: white; padding: 20px; border-radius: 12px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .metric span { display: block; font-size: 0.75rem; color: var(--text-muted); font-weight: 800; text-transform: uppercase; margin-bottom: 5px; }
        .metric strong { font-size: 1.3rem; color: var(--primary); }
        
        .ai-feedback { background: white; padding: 20px; border-radius: 12px; border-left: 5px solid var(--accent); }
        .ai-feedback h5 { color: var(--accent-dark); margin-bottom: 10px; font-size: 1rem; }

        footer { 
            background-color: #1e293b; 
            color: #f1f5f9; 
            text-align: center; 
            padding: 60px 20px; 
            margin-top: 60px; 
        }
        footer p { margin-bottom: 10px; opacity: 0.8; }
        .footer-names { font-weight: bold; color: var(--accent); font-size: 1.1rem; }
    </style>
</head>
<body>

    <header>
        <h1>Siembra Inteligente: Agua y Vida en el Campo</h1>
        <p>Soluciones de ingeniería y tecnología aplicada para la sustentabilidad hídrica rural.</p>
        <span class="badge">🤖 Innovación con IA - 3er Año de Bachillerato</span>
    </header>

    <main>
        <section class="intro-box">
            <h2>Nuestra Misión</h2>
            <p>Hola, mi nombre es <strong>Airam</strong>, y junto con mis compañeros <strong>Brisa, Joshuan y Pedro</strong>, hemos desarrollado esta plataforma web que implementa <strong>Inteligencia Artificial</strong> para resolver una problemática crítica en nuestra comunidad: el desperdicio de agua en el riego agrícola.</p>
            <p style="margin-top: 15px; border-top: 1px solid #eee; padding-top: 15px; font-style: italic;">Esta actividad se lleva a cabo en la clase del <strong>maestro Cecilio</strong>, dentro de la asignatura de <strong>Humanidades III</strong>, la cual cursamos en el <strong>Centro de Bachillerato Tecnológico Agropecuario (CBTa 130)</strong>. Como estudiantes de 3er año, nuestro objetivo es fusionar la tecnología moderna con el campo para crear un futuro más sustentable.</p>
        </section>

        <section class="stats-grid">
            <div class="stat-card">
                <h4>70%</h4>
                <p>Uso de agua dulce en el campo</p>
            </div>
            <div class="stat-card">
                <h4>40%</h4>
                <p>Desperdicio por evaporación</p>
            </div>
            <div class="stat-card">
                <h4>50%</h4>
                <p>Ahorro potencial con nuestra IA</p>
            </div>
        </section>

        <section class="grid">
            <div class="card">
                <h3>Buenas Prácticas de Riego</h3>
                <ul>
                    <li><strong>Horarios estratégicos:</strong> El riego nocturno o al amanecer reduce la pérdida por calor en un 30%.</li>
                    <li><strong>Sensores de Suelo:</strong> Evitan el riego innecesario cuando la tierra ya tiene la humedad óptima.</li>
                    <li><strong>Mantenimiento:</strong> Una pequeña fuga puede desperdiciar hasta 2,000 litros de agua al día.</li>
                </ul>
            </div>
            <div class="card">
                <h3>Ventajas Tecnológicas</h3>
                <ul>
                    <li><strong>Precisión Agrícola:</strong> Entrega exactamente los milímetros de agua que la planta requiere.</li>
                    <li><strong>Recuperación de Acuíferos:</strong> Al usar menos agua, permitimos que los pozos locales se regeneren.</li>
                    <li><strong>Eficiencia Económica:</strong> Menos gasto en bombeo eléctrico y combustible para las familias.</li>
                </ul>
            </div>
        </section>

        <section class="data-table-container">
            <h3 style="color: var(--primary); margin-bottom: 15px;">Parámetros Técnicos de Cultivo</h3>
            <table>
                <thead>
                    <tr>
                        <th>Cultivo</th>
                        <th>Suelo Ideal</th>
                        <th>Demanda Hídrica</th>
                        <th>Dato de la IA</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Maíz</td>
                        <td>Franco / Negro</td>
                        <td>Moderada</td>
                        <td>Sensible a la floración</td>
                    </tr>
                    <tr>
                        <td>Frijol</td>
                        <td>Arcilloso</td>
                        <td>Baja</td>
                        <td>Evitar encharcamiento</td>
                    </tr>
                    <tr>
                        <td>Hortalizas</td>
                        <td>Fértil / Rico</td>
                        <td>Alta</td>
                        <td>Riego por pulsos cortos</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <section class="simulator-section">
            <h2>Simulador de Riego de Precisión</h2>
            <div class="sim-grid">
                <div class="controls">
                    <div class="control-group">
                        <label>1. Cultivo seleccionado:</label>
                        <select id="cultivo">
                            <option value="maiz">Maíz</option>
                            <option value="frijol">Frijol</option>
                            <option value="hortalizas">Hortalizas</option>
                        </select>
                    </div>
                    <div class="control-group">
                        <label>2. Tipo de suelo detectado:</label>
                        <select id="suelo">
                            <option value="arcilloso">Arcilloso (Retiene humedad)</option>
                            <option value="arenoso">Arenoso (Drena rápido)</option>
                            <option value="franco">Franco (Equilibrado)</option>
                        </select>
                    </div>
                    <div class="control-group">
                        <label>3. Condición climática:</label>
                        <select id="clima">
                            <option value="caluroso">Caluroso (>30°C)</option>
                            <option value="nublado">Nublado / Templado</option>
                            <option value="lluvioso">Lluvia activa</option>
                        </select>
                    </div>
                    <button class="btn-sim" onclick="analizarRiego()">EJECUTAR ANÁLISIS DE IA</button>
                </div>

                <div class="results" id="res-box">
                    <h4 style="text-align: center; color: var(--accent-dark); margin-bottom: 20px; font-weight: 800;">DIAGNÓSTICO TÉCNICO</h4>
                    <div class="metric-box">
                        <div class="metric">
                            <span>Lámina de Agua</span>
                            <strong id="volumen">- - -</strong>
                        </div>
                        <div class="metric">
                            <span>Momento del Día</span>
                            <strong id="momento">- - -</strong>
                        </div>
                    </div>
                    <div class="ai-feedback">
                        <h5>🤖 Procesamiento de Datos:</h5>
                        <p id="diagnostico" style="font-size: 0.95rem;">Configure las variables para obtener la recomendación científica del equipo.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <p><strong>Proyecto Integrador: Tecnología para la Comunidad</strong></p>
        <p class="footer-names">Airam, Brisa, Joshuan y Pedro</p>
        <p>3er Año de Bachillerato | CBTa 130 | Humanidades III</p>
        <p>Asignatura a cargo del Maestro Cecilio</p>
        <p>© 2026 - Desarrollo rural sustentable.</p>
    </footer>

    <script>
        function analizarRiego() {
            const cultivo = document.getElementById('cultivo').value;
            const suelo = document.getElementById('suelo').value;
            const clima = document.getElementById('clima').value;

            let vol = ""; let mom = ""; let diag = "";

            if (clima === 'lluvioso') {
                vol = "0 mm"; mom = "Pausar Sistema";
                diag = "La IA detecta precipitación natural. Se recomienda suspender el riego automático para evitar asfixia radicular y lixiviación de nutrientes.";
            } else {
                if (suelo === 'arenoso') {
                    vol = "15 - 20 mm"; mom = "6:00 AM";
                    diag = "El suelo arenoso drena muy rápido. Aplicar un riego profundo temprano para asegurar que la raíz absorba el agua antes del pico de calor.";
                } else if (suelo === 'arcilloso') {
                    vol = "8 - 10 mm"; mom = "7:00 PM";
                    diag = "Suelo con alta capacidad de retención. Riego ligero al atardecer para evitar encharcamientos y desarrollo de hongos por exceso de humedad.";
                } else {
                    vol = "12 - 15 mm"; mom = "Al Amanecer";
                    diag = "Suelo franco detectado. Las condiciones son ideales. Mantener la humedad constante para un crecimiento vigoroso del cultivo.";
                }
            }

            document.getElementById('volumen').innerText = vol;
            document.getElementById('momento').innerText = mom;
            document.getElementById('diagnostico').innerText = diag;
        }
    </script>
</body>
</html>
